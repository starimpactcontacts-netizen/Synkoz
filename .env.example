# Supabase project (public client config — safe to expose in the web build).
# Find these in: Supabase dashboard -> Project Settings -> API.
#   URL        = "Project URL"
#   ANON KEY   = "Project API keys" -> "anon public" (a.k.a. publishable key)
#
# These must also be set as Environment Variables on the Vercel project so the
# web build (`expo export -p web`) picks them up. Until the ANON KEY is set, the
# app runs on local mock data (see src/lib/supabase.ts -> isSupabaseConfigured).
EXPO_PUBLIC_SUPABASE_URL=https://jcllxgxetklyjlknakdz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
